---
import 'src/styles/global.css';

export const prerender = true

export interface Props {
    title: string;
    description?: string;
    keywords?: string;
    ogImage?: string;
    ogType?: string;
    canonicalUrl?: string;
    noindex?: boolean;
}

const { 
    title, 
    description = "SPLITDO - Blockchain-powered bill splitting on Solana. Join the token presale and split expenses with crypto. Lightning-fast settlements, near-zero fees.",
    keywords = "SPLITDO, Solana token, bill splitting, crypto presale, blockchain payments, expense sharing, DeFi, cryptocurrency",
    ogImage = "/splitdo/logo.svg",
    ogType = "website",
    canonicalUrl,
    noindex = false
} = Astro.props;

// Google Analytics - read at build time (prerendered pages)
const gaMeasurementId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_MEASUREMENT_ID;

// Build-time logging for Cloudflare Pages build logs
if (gaMeasurementId) {
    console.log(`[GA] Google Analytics measurement ID loaded successfully: ${gaMeasurementId.substring(0, 4)}****`);
} else {
    console.warn('[GA] WARNING: GOOGLE_ANALYTICS_MEASUREMENT_ID_PUBLIC_PAGES env var is not set. Google Analytics will NOT be included in prerendered pages.');
    console.warn('[GA] Set GOOGLE_ANALYTICS_MEASUREMENT_ID_PUBLIC_PAGES in Cloudflare Pages environment variables.');
}

// Build full canonical URL
const fullCanonicalUrl = canonicalUrl || `https://splitdo.app${Astro.url.pathname}`;
// Build full OG image URL
const fullOgImage = ogImage.startsWith('http') ? ogImage : `https://splitdo.app${ogImage}`;
---

<!doctype html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="SplitDo" />
    <link rel="canonical" href={fullCanonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={fullCanonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:site_name" content="SplitDo" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullCanonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={fullOgImage} />
    
    <!-- Apple Touch Icon -->
    <link rel="apple-touch-icon" href="/splitdo/logo.svg" />
    
    <!-- Structured Data - Organization -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "SplitDo",
      "url": "https://splitdo.app",
      "logo": "https://splitdo.app/splitdo/logo.svg",
      "description": "Blockchain-powered bill splitting on Solana",
      "sameAs": []
    }
    </script>

    <!-- Google Analytics (gtag.js) - only included when measurement ID is set -->
    {gaMeasurementId && (
        <>
            <script is:inline define:vars={{ gaMeasurementId }}>
                // Load gtag.js dynamically to avoid CSP issues with direct script src in Astro
                (function() {
                    var s = document.createElement('script');
                    s.async = true;
                    s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaMeasurementId;
                    document.head.appendChild(s);
                })();

                window.dataLayer = window.dataLayer || [];
                function gtag(){dataLayer.push(arguments);}
                gtag('js', new Date());
                gtag('config', gaMeasurementId);
            </script>
        </>
    )}

    <script is:inline>
        // Prevent flash of light mode
        const isDarkMode = localStorage.getItem('darkMode') === 'true' ||
            (!localStorage.getItem('darkMode') && window.matchMedia('(prefers-color-scheme: dark)').matches);

        if (isDarkMode) {
            document.documentElement.classList.add('dark');
        }
    </script>
</head>
<body class="bg-zinc-950 text-white max-w-full overflow-x-hidden">

<!-- Navigation -->
<header class="fixed top-0 left-0 right-0 z-50 bg-zinc-950/90 backdrop-blur-xl border-b border-zinc-800 max-w-full overflow-hidden">
    <nav class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12 w-full max-w-full">
        <div class="flex justify-between items-center h-20">
            <!-- Logo -->
            <a href="/" class="flex items-center group transition-transform hover:scale-105">
                <img src="/splitdo/logo.svg" alt="SplitDo Logo" class="h-12 w-auto" />
            </a>

            <!-- Desktop Navigation -->
            <div class="hidden lg:flex items-center gap-10">
                <a href="/" class="text-sm font-medium text-zinc-400 hover:text-white transition-colors">
                    Home
                </a>
                <a href="/download" class="text-sm font-medium text-zinc-400 hover:text-white transition-colors">
                    Download
                </a>
                <a href="/tokenomics" class="text-sm font-medium text-zinc-400 hover:text-white transition-colors">
                    Tokenomics
                </a>
                <a href="/guide" class="text-sm font-medium text-zinc-400 hover:text-white transition-colors">
                    Guide
                </a>
                <a href="/about" class="text-sm font-medium text-zinc-400 hover:text-white transition-colors">
                    About
                </a>

                <a href="/app/dashboard" class="px-6 py-2.5 bg-cyan-500 text-black font-semibold hover:bg-cyan-400 transition-colors">
                    Launch App
                </a>
            </div>

            <!-- Mobile Menu Button -->
            <div class="lg:hidden flex items-center">
                <button
                    id="mobile-menu-button"
                    type="button"
                    class="text-zinc-400 hover:text-white p-2 transition-colors"
                    aria-controls="mobile-menu"
                    aria-expanded="false"
                >
                    <span class="sr-only">Open main menu</span>
                    <svg class="h-6 w-6" id="menu-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                    <svg class="h-6 w-6 hidden" id="close-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div class="lg:hidden hidden" id="mobile-menu">
            <div class="px-4 pt-2 pb-4 space-y-1 bg-zinc-950 border-t border-zinc-800">
                <a href="/" class="block px-3 py-3 text-base font-medium text-zinc-400 hover:text-white transition-colors">Home</a>
                <a href="/download" class="block px-3 py-3 text-base font-medium text-zinc-400 hover:text-white transition-colors">Download</a>
                <a href="/tokenomics" class="block px-3 py-3 text-base font-medium text-zinc-400 hover:text-white transition-colors">Tokenomics</a>
                <a href="/guide" class="block px-3 py-3 text-base font-medium text-zinc-400 hover:text-white transition-colors">Guide</a>
                <a href="/about" class="block px-3 py-3 text-base font-medium text-zinc-400 hover:text-white transition-colors">About</a>
                <div class="pt-4">
                    <a href="/app/dashboard" class="block w-full px-6 py-3 bg-cyan-500 text-black font-semibold text-center hover:bg-cyan-400 transition-colors">
                        Launch App
                    </a>
                </div>
            </div>
        </div>
    </nav>
</header>

<!-- Main content -->
<main class="pt-24">
    <slot />
</main>

<!-- Footer -->
<footer class="bg-zinc-950 border-t border-zinc-800 py-16 mt-24">
    <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
            <!-- Brand -->
            <div class="col-span-1 md:col-span-2">
                <a href="/" class="flex items-center mb-6">
                    <img src="/splitdo/logo.svg" alt="SplitDo Logo" class="h-10 w-auto" />
                </a>
                <p class="text-zinc-500 text-sm max-w-md leading-relaxed">
                    Split bills, track expenses, and settle up with friends. The future of group expense management on Solana.
                </p>
            </div>

            <!-- Quick Links -->
            <div>
                <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-6">Quick Links</h3>
                <ul class="space-y-3">
                    <li><a href="/" class="text-zinc-500 hover:text-cyan-400 text-sm transition-colors">Home</a></li>
                    <li><a href="/download" class="text-zinc-500 hover:text-cyan-400 text-sm transition-colors">Download</a></li>
                    <li><a href="/tokenomics" class="text-zinc-500 hover:text-cyan-400 text-sm transition-colors">Tokenomics</a></li>
                    <li><a href="/about" class="text-zinc-500 hover:text-cyan-400 text-sm transition-colors">About</a></li>
                </ul>
            </div>

            <!-- Community -->
            <div>
                <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-6">Community</h3>
                <ul class="space-y-3">
                    <li>
                        <a href="javascript:void(0)" onclick="openTelegram()" class="text-zinc-500 hover:text-cyan-400 text-sm transition-colors">
                            Telegram
                        </a>
                    </li>
                    <li>
                        <a href="javascript:void(0)" onclick="openDiscord()" class="text-zinc-500 hover:text-cyan-400 text-sm transition-colors">
                            Discord
                        </a>
                    </li>
                    <li>
                        <a href="javascript:void(0)" onclick="openWhatsApp()" class="text-zinc-500 hover:text-cyan-400 text-sm transition-colors">
                            WhatsApp
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <div class="border-t border-zinc-800 mt-12 pt-8">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                <p class="text-zinc-600 text-xs">
                    © 2024 SplitDo. All rights reserved.
                </p>
                <div class="flex space-x-6">
                    <a href="#" class="text-zinc-600 hover:text-zinc-400 text-xs transition-colors">Privacy Policy</a>
                    <a href="#" class="text-zinc-600 hover:text-zinc-400 text-xs transition-colors">Terms of Service</a>
                </div>
            </div>
        </div>
    </div>
</footer>

<script>
// Support channel navigation functions - defined globally
window.openTelegram = function() {
    const userAgent = navigator.userAgent || navigator.vendor || window.opera;
    const isAndroid = /android/i.test(userAgent);
    const isIOS = /iPad|iPhone|iPod/.test(userAgent) && !window.MSStream;

    if (isAndroid || isIOS) {
        // Try to open in Telegram app first
        window.location.href = 'tg://resolve?domain=splitdo_support_bot';

        // Fallback to web version after a short delay
        setTimeout(() => {
            window.open('https://web.telegram.org/k/#@splitdo_support_bot', '_blank');
        }, 1000);
    } else {
        // Desktop - open web version directly
        window.open('https://web.telegram.org/k/#@splitdo_support_bot', '_blank');
    }
};

window.openDiscord = function() {
    const userAgent = navigator.userAgent || navigator.vendor || window.opera;
    const isAndroid = /android/i.test(userAgent);
    const isIOS = /iPad|iPhone|iPod/.test(userAgent) && !window.MSStream;

    if (isAndroid || isIOS) {
        // Try to open in Discord app first
        window.location.href = 'discord://discord.com/channels/1454446948915347550/1454446949699944492';

        // Fallback to web version after a short delay
        setTimeout(() => {
            window.open('https://discord.com/channels/1454446948915347550/1454446949699944492', '_blank');
        }, 1000);
    } else {
        // Desktop - open web version directly
        window.open('https://discord.com/channels/1454446948915347550/1454446949699944492', '_blank');
    }
};

window.openWhatsApp = function() {
    const userAgent = navigator.userAgent || navigator.vendor || window.opera;
    const isAndroid = /android/i.test(userAgent);
    const isIOS = /iPad|iPhone|iPod/.test(userAgent) && !window.MSStream;

    if (isAndroid || isIOS) {
        // Try to open in WhatsApp app first
        window.location.href = 'whatsapp://send?phone=971569119332';

        // Fallback to web version after a short delay
        setTimeout(() => {
            window.open('https://wa.me/971569119332', '_blank');
        }, 1000);
    } else {
        // Desktop - open web version directly
        window.open('https://wa.me/971569119332', '_blank');
    }
};

// Mobile menu toggle - run immediately and also on DOMContentLoaded for iOS Safari
function initMobileMenu() {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    if (!mobileMenuButton) return;
    
    // Remove any existing listeners to avoid duplicates
    const newButton = mobileMenuButton.cloneNode(true);
    mobileMenuButton.parentNode?.replaceChild(newButton, mobileMenuButton);
    
    newButton.addEventListener('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        
        const menu = document.getElementById('mobile-menu');
        const menuIcn = document.getElementById('menu-icon');
        const closeIcn = document.getElementById('close-icon');
        const isExpanded = newButton.getAttribute('aria-expanded') === 'true';

        newButton.setAttribute('aria-expanded', String(!isExpanded));
        menu?.classList.toggle('hidden');
        menuIcn?.classList.toggle('hidden');
        closeIcn?.classList.toggle('hidden');
    });
}

// Try to init immediately
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileMenu);
} else {
    initMobileMenu();
}

// Also try on load as fallback for iOS Safari
window.addEventListener('load', initMobileMenu);
</script>
</body>
</html>