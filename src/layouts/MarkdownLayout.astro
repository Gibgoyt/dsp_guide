---
const { frontmatter } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{frontmatter.title}</title>
		{frontmatter.description && <meta name="description" content={frontmatter.description} />}
		<link rel="stylesheet" href="/src/styles/global.css" />
		<script src="https://cdn.tailwindcss.com"></script>
		<script>
			tailwind.config = {
				darkMode: 'class',
			}
		</script>
	</head>
	<body class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100">
		<main>
			<!-- Hero Section -->
			<section class="bg-gradient-to-b from-gray-50 to-white dark:from-gray-900 dark:to-gray-800 py-16 lg:py-24">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
					<div class="text-center">
						<div class="w-20 h-20 bg-gray-700 rounded-2xl flex items-center justify-center mx-auto mb-6">
							<span class="text-white font-bold text-2xl">MD</span>
						</div>
						<h1 class="text-4xl lg:text-5xl font-bold mb-6">{frontmatter.title}</h1>
						{frontmatter.description && (
							<p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto">
								{frontmatter.description}
							</p>
						)}
						{frontmatter.author && (
							<p class="text-lg text-gray-500 dark:text-gray-400 mt-4">
								By {frontmatter.author}
								{frontmatter.date && ` • ${frontmatter.date}`}
							</p>
						)}
					</div>
				</div>
			</section>

			<!-- Content Section -->
			<section class="py-16 lg:py-24">
				<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
					<div class="prose prose-lg prose-gray dark:prose-invert max-w-none">
						<slot />
					</div>
				</div>
			</section>

			<!-- Back Link -->
			<section class="py-16 bg-gray-50 dark:bg-gray-900">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
					<a href="/apps" class="inline-flex items-center px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
						<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
						</svg>
						Back to Applications Hub
					</a>
				</div>
			</section>
		</main>

		<style>
			/* Custom prose styles for markdown content */
			.prose {
				line-height: 1.7;
			}
			
			.prose h1 {
				font-size: 2.25rem;
				font-weight: 700;
				margin-top: 2rem;
				margin-bottom: 1rem;
				color: inherit;
			}
			
			.prose h2 {
				font-size: 1.875rem;
				font-weight: 600;
				margin-top: 2rem;
				margin-bottom: 1rem;
				color: inherit;
			}
			
			.prose h3 {
				font-size: 1.5rem;
				font-weight: 600;
				margin-top: 1.5rem;
				margin-bottom: 0.75rem;
				color: inherit;
			}
			
			.prose h4 {
				font-size: 1.25rem;
				font-weight: 600;
				margin-top: 1.5rem;
				margin-bottom: 0.5rem;
				color: inherit;
			}
			
			.prose p {
				margin-bottom: 1.25rem;
			}
			
			.prose strong {
				font-weight: 600;
				color: inherit;
			}
			
			.prose em {
				font-style: italic;
			}
			
			.prose ul, .prose ol {
				margin: 1.25rem 0;
				padding-left: 1.5rem;
			}
			
			.prose li {
				margin: 0.5rem 0;
			}
			
			.prose ul li {
				list-style-type: disc;
			}
			
			.prose ol li {
				list-style-type: decimal;
			}
			
			.prose blockquote {
				border-left: 4px solid #e5e7eb;
				padding-left: 1rem;
				margin: 1.5rem 0;
				font-style: italic;
				color: #6b7280;
			}
			
			.dark .prose blockquote {
				border-left-color: #4b5563;
				color: #9ca3af;
			}
			
			.prose code {
				background-color: #f3f4f6;
				color: #e11d48;
				padding: 0.25rem 0.375rem;
				border-radius: 0.25rem;
				font-size: 0.875em;
			}
			
			.dark .prose code {
				background-color: #374151;
				color: #fbbf24;
			}
			
			.prose pre {
				background-color: #f8fafc;
				border: 1px solid #e2e8f0;
				border-radius: 0.5rem;
				padding: 1rem;
				overflow-x: auto;
				margin: 1.5rem 0;
			}
			
			.dark .prose pre {
				background-color: #1f2937;
				border-color: #374151;
			}
			
			.prose pre code {
				background: none;
				color: inherit;
				padding: 0;
			}
			
			.prose table {
				width: 100%;
				border-collapse: collapse;
				margin: 1.5rem 0;
			}
			
			.prose th, .prose td {
				border: 1px solid #e5e7eb;
				padding: 0.75rem;
				text-align: left;
			}
			
			.dark .prose th, .dark .prose td {
				border-color: #4b5563;
			}
			
			.prose th {
				background-color: #f9fafb;
				font-weight: 600;
			}
			
			.dark .prose th {
				background-color: #374151;
			}
			
			.prose a {
				color: #3b82f6;
				text-decoration: underline;
			}
			
			.prose a:hover {
				color: #2563eb;
			}
			
			.dark .prose a {
				color: #60a5fa;
			}
			
			.dark .prose a:hover {
				color: #93c5fd;
			}
			
			.prose hr {
				border: none;
				border-top: 1px solid #e5e7eb;
				margin: 2rem 0;
			}
			
			.dark .prose hr {
				border-top-color: #4b5563;
			}
		</style>
	</body>
</html>