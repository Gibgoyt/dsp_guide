---
import Layout from 'src/layouts/Layout.astro';

export const prerender = true;
---

<Layout 
  title="SPLITDO Tokenomics | Token Distribution & Utility on Solana"
  description="SPLITDO token economics: 100M total supply, 31.5% strategic sale, Solana-based utility token. Transparent distribution, governance rights, staking rewards, and vesting schedules."
  keywords="SPLITDO tokenomics, token distribution, Solana token, crypto presale allocation, vesting schedule, utility token, DeFi governance, token economics"
  ogType="website"
>
  <style>
    .text-gradient {
      background: linear-gradient(135deg, #22d3ee 0%, #3b82f6 50%, #8b5cf6 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
  </style>

  <main class="bg-zinc-950 text-white min-h-screen">

    <!-- Hero -->
    <section class="py-24 sm:py-32 px-6 border-b border-zinc-800">
      <div class="max-w-5xl mx-auto">
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black mb-6">
          <span class="text-gradient">$SPLITDO</span><br/>
          Tokenomics
        </h1>
        <p class="text-xl text-zinc-400 max-w-2xl mb-12">
          A utility-first token designed for real-world settlement infrastructure. Not speculation.
        </p>

        <!-- Key Stats -->
        <div class="flex flex-wrap gap-8 sm:gap-16">
          <div>
            <div class="text-4xl sm:text-5xl font-black text-cyan-400">100M</div>
            <div class="text-sm text-zinc-500 mt-1">Total Supply</div>
          </div>
          <div>
            <div class="text-4xl sm:text-5xl font-black">Utility</div>
            <div class="text-sm text-zinc-500 mt-1">Token Type</div>
          </div>
          <div>
            <div class="text-4xl sm:text-5xl font-black">Solana</div>
            <div class="text-sm text-zinc-500 mt-1">Blockchain</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Token Purpose -->
    <section class="py-24 sm:py-32 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="mb-16">
          <h2 class="text-4xl sm:text-5xl font-black mb-4">Purpose</h2>
          <p class="text-xl text-zinc-500 max-w-2xl">
            The token is not the product. It's a coordination tool.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
          <div>
            <h3 class="text-xl font-bold mb-2">Reduce Fees</h3>
            <p class="text-zinc-500">Lower platform costs for token holders.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-2">Reward Usage</h3>
            <p class="text-zinc-500">Incentivize genuine platform activity.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-2">Governance</h3>
            <p class="text-zinc-500">Enable community-driven decisions.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold mb-2">Growth</h3>
            <p class="text-zinc-500">Support ecosystem expansion.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Distribution -->
    <section class="py-24 sm:py-32 px-6 bg-zinc-900/50">
      <div class="max-w-5xl mx-auto">
        <div class="mb-16">
          <h2 class="text-4xl sm:text-5xl font-black mb-4">Distribution</h2>
          <p class="text-xl text-zinc-500">Fixed supply. No inflation. No hidden minting.</p>
        </div>

        <div class="grid lg:grid-cols-2 gap-16">
          <!-- Chart Visual -->
          <div class="flex justify-center items-center">
            <div class="relative">
              <svg viewBox="0 0 400 400" class="w-full max-w-sm">
                <!-- Strategic/Institutional: 31.5% -->
                <circle cx="200" cy="200" r="140" fill="none" stroke="#22d3ee" stroke-width="50"
                  stroke-dasharray="277 880" transform="rotate(-90 200 200)" />
                <!-- Liquidity: 20% -->
                <circle cx="200" cy="200" r="140" fill="none" stroke="#3b82f6" stroke-width="50"
                  stroke-dasharray="176 880" stroke-dashoffset="-277" transform="rotate(-90 200 200)" />
                <!-- Treasury: 10% -->
                <circle cx="200" cy="200" r="140" fill="none" stroke="#6366f1" stroke-width="50"
                  stroke-dasharray="88 880" stroke-dashoffset="-453" transform="rotate(-90 200 200)" />
                <!-- Strategic Partners: 10% -->
                <circle cx="200" cy="200" r="140" fill="none" stroke="#8b5cf6" stroke-width="50"
                  stroke-dasharray="88 880" stroke-dashoffset="-541" transform="rotate(-90 200 200)" />
                <!-- Team: 10% -->
                <circle cx="200" cy="200" r="140" fill="none" stroke="#a855f7" stroke-width="50"
                  stroke-dasharray="88 880" stroke-dashoffset="-629" transform="rotate(-90 200 200)" />
                <!-- Seed: 8.5% -->
                <circle cx="200" cy="200" r="140" fill="none" stroke="#52525b" stroke-width="50"
                  stroke-dasharray="75 880" stroke-dashoffset="-717" transform="rotate(-90 200 200)" />
                <!-- Marketing: 5% -->
                <circle cx="200" cy="200" r="140" fill="none" stroke="#71717a" stroke-width="50"
                  stroke-dasharray="44 880" stroke-dashoffset="-792" transform="rotate(-90 200 200)" />
                <!-- Legal: 5% -->
                <circle cx="200" cy="200" r="140" fill="none" stroke="#a1a1aa" stroke-width="50"
                  stroke-dasharray="44 880" stroke-dashoffset="-836" transform="rotate(-90 200 200)" />
                <!-- Center -->
                <text x="200" y="195" text-anchor="middle" class="fill-white text-3xl font-black">100M</text>
                <text x="200" y="220" text-anchor="middle" class="fill-zinc-500 text-sm">Total Supply</text>
              </svg>
            </div>
          </div>

          <!-- Allocation List -->
          <div class="space-y-4">
            <div class="flex items-center justify-between py-4 border-b border-zinc-800">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-cyan-400"></div>
                <div>
                  <div class="font-semibold">Strategic / Institutional</div>
                  <div class="text-sm text-zinc-600">31,500,000 tokens</div>
                </div>
              </div>
              <div class="text-2xl font-black text-cyan-400">31.5%</div>
            </div>

            <div class="flex items-center justify-between py-4 border-b border-zinc-800">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-blue-500"></div>
                <div>
                  <div class="font-semibold">Liquidity & Market Support</div>
                  <div class="text-sm text-zinc-600">20,000,000 tokens</div>
                </div>
              </div>
              <div class="text-2xl font-black">20%</div>
            </div>

            <div class="flex items-center justify-between py-4 border-b border-zinc-800">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-indigo-500"></div>
                <div>
                  <div class="font-semibold">Treasury & Future Dev</div>
                  <div class="text-sm text-zinc-600">10,000,000 tokens</div>
                </div>
              </div>
              <div class="text-2xl font-black">10%</div>
            </div>

            <div class="flex items-center justify-between py-4 border-b border-zinc-800">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-violet-500"></div>
                <div>
                  <div class="font-semibold">Strategic Partners</div>
                  <div class="text-sm text-zinc-600">10,000,000 tokens</div>
                </div>
              </div>
              <div class="text-2xl font-black">10%</div>
            </div>

            <div class="flex items-center justify-between py-4 border-b border-zinc-800">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-purple-500"></div>
                <div>
                  <div class="font-semibold">Team & Advisors</div>
                  <div class="text-sm text-zinc-600">10,000,000 tokens</div>
                </div>
              </div>
              <div class="text-2xl font-black">10%</div>
            </div>

            <div class="flex items-center justify-between py-4 border-b border-zinc-800">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-zinc-600"></div>
                <div>
                  <div class="font-semibold">Seed Contributors</div>
                  <div class="text-sm text-zinc-600">8,500,000 tokens</div>
                </div>
              </div>
              <div class="text-2xl font-black">8.5%</div>
            </div>

            <div class="flex items-center justify-between py-4 border-b border-zinc-800">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-zinc-500"></div>
                <div>
                  <div class="font-semibold">Marketing & Ecosystem</div>
                  <div class="text-sm text-zinc-600">5,000,000 tokens</div>
                </div>
              </div>
              <div class="text-2xl font-black">5%</div>
            </div>

            <div class="flex items-center justify-between py-4">
              <div class="flex items-center gap-3">
                <div class="w-3 h-3 bg-zinc-400"></div>
                <div>
                  <div class="font-semibold">Legal & Compliance</div>
                  <div class="text-sm text-zinc-600">5,000,000 tokens</div>
                </div>
              </div>
              <div class="text-2xl font-black">5%</div>
            </div>
          </div>
        </div>

        <!-- Priorities -->
        <div class="grid sm:grid-cols-3 gap-8 mt-20">
          <div class="text-center">
            <div class="text-3xl font-black text-gradient mb-2">Liquidity</div>
            <p class="text-zinc-500">Market stability first</p>
          </div>
          <div class="text-center">
            <div class="text-3xl font-black text-gradient mb-2">Execution</div>
            <p class="text-zinc-500">Over speculation</p>
          </div>
          <div class="text-center">
            <div class="text-3xl font-black text-gradient mb-2">Long-term</div>
            <p class="text-zinc-500">Alignment over exits</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Vesting -->
    <section class="py-24 sm:py-32 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="mb-16">
          <h2 class="text-4xl sm:text-5xl font-black mb-4">Vesting</h2>
          <p class="text-xl text-zinc-500">All major allocations are vested. No immediate insider liquidity.</p>
        </div>

        <div class="grid sm:grid-cols-2 gap-8">
          <div class="p-6 bg-zinc-900">
            <h3 class="text-lg font-bold mb-2">Team & Advisors</h3>
            <p class="text-zinc-400 mb-1">12-month cliff, 36-month linear vesting</p>
            <p class="text-sm text-zinc-600">Long-term commitment to execution</p>
          </div>
          <div class="p-6 bg-zinc-900">
            <h3 class="text-lg font-bold mb-2">Seed Contributors</h3>
            <p class="text-zinc-400 mb-1">Partial TGE unlock, linear vesting</p>
            <p class="text-sm text-zinc-600">Rewarding early risk-takers</p>
          </div>
          <div class="p-6 bg-zinc-900">
            <h3 class="text-lg font-bold mb-2">Strategic Partners</h3>
            <p class="text-zinc-400 mb-1">Milestone-aligned linear vesting</p>
            <p class="text-sm text-zinc-600">Performance-based unlocks</p>
          </div>
          <div class="p-6 bg-zinc-900">
            <h3 class="text-lg font-bold mb-2">Treasury</h3>
            <p class="text-zinc-400 mb-1">Time-locked, governance-controlled</p>
            <p class="text-sm text-zinc-600">Community-driven allocation</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Competitive Positioning -->
    <section class="py-24 sm:py-32 px-6 bg-zinc-900/50">
      <div class="max-w-5xl mx-auto">
        <div class="mb-16">
          <h2 class="text-4xl sm:text-5xl font-black mb-4">Competitive Edge</h2>
          <p class="text-xl text-zinc-500">We replace the part that never worked well.</p>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full min-w-[600px]">
            <thead>
              <tr class="border-b-2 border-cyan-500">
                <th class="text-left py-4 px-4 font-bold">Platform</th>
                <th class="text-center py-4 px-4 font-bold">Tracks</th>
                <th class="text-center py-4 px-4 font-bold">Instant Settle</th>
                <th class="text-center py-4 px-4 font-bold">Global</th>
                <th class="text-center py-4 px-4 font-bold">On-Chain</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-zinc-800">
                <td class="py-4 px-4 font-medium">Splitwise</td>
                <td class="py-4 px-4 text-center"><span class="text-emerald-400">Yes</span></td>
                <td class="py-4 px-4 text-center"><span class="text-red-400">No</span></td>
                <td class="py-4 px-4 text-center"><span class="text-yellow-400">Limited</span></td>
                <td class="py-4 px-4 text-center"><span class="text-red-400">No</span></td>
              </tr>
              <tr class="border-b border-zinc-800">
                <td class="py-4 px-4 font-medium">Tricount</td>
                <td class="py-4 px-4 text-center"><span class="text-emerald-400">Yes</span></td>
                <td class="py-4 px-4 text-center"><span class="text-red-400">No</span></td>
                <td class="py-4 px-4 text-center"><span class="text-yellow-400">Limited</span></td>
                <td class="py-4 px-4 text-center"><span class="text-red-400">No</span></td>
              </tr>
              <tr class="border-b border-zinc-800">
                <td class="py-4 px-4 font-medium">Group Payments</td>
                <td class="py-4 px-4 text-center"><span class="text-yellow-400">Partial</span></td>
                <td class="py-4 px-4 text-center"><span class="text-yellow-400">Partial</span></td>
                <td class="py-4 px-4 text-center"><span class="text-red-400">No</span></td>
                <td class="py-4 px-4 text-center"><span class="text-red-400">No</span></td>
              </tr>
              <tr class="bg-cyan-500/10">
                <td class="py-4 px-4 font-bold text-cyan-400">SplitDo</td>
                <td class="py-4 px-4 text-center"><span class="text-emerald-400 font-bold">Yes</span></td>
                <td class="py-4 px-4 text-center"><span class="text-emerald-400 font-bold">Yes</span></td>
                <td class="py-4 px-4 text-center"><span class="text-emerald-400 font-bold">Yes</span></td>
                <td class="py-4 px-4 text-center"><span class="text-emerald-400 font-bold">Yes</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Value Flow -->
    <section class="py-24 sm:py-32 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="mb-16">
          <h2 class="text-4xl sm:text-5xl font-black mb-4">Value Flow</h2>
          <p class="text-xl text-zinc-500">No artificial demand. Usage creates value. Nothing else.</p>
        </div>

        <div class="space-y-6 max-w-2xl">
          <div class="flex gap-6 items-start">
            <div class="w-12 h-12 bg-cyan-500 text-zinc-950 font-bold text-xl flex items-center justify-center flex-shrink-0">1</div>
            <div>
              <h3 class="text-xl font-bold mb-1">Users Pay Service Fee</h3>
              <p class="text-zinc-500">Small fee on platform transactions for settlement services.</p>
            </div>
          </div>
          <div class="flex gap-6 items-start">
            <div class="w-12 h-12 bg-zinc-800 text-white font-bold text-xl flex items-center justify-center flex-shrink-0">2</div>
            <div>
              <h3 class="text-xl font-bold mb-1">Token Holders Get Discounts</h3>
              <p class="text-zinc-500">Holding tokens provides fee reductions or rebates.</p>
            </div>
          </div>
          <div class="flex gap-6 items-start">
            <div class="w-12 h-12 bg-zinc-800 text-white font-bold text-xl flex items-center justify-center flex-shrink-0">3</div>
            <div>
              <h3 class="text-xl font-bold mb-1">Fees Support Ecosystem</h3>
              <p class="text-zinc-500">Revenue funds incentives, liquidity, and treasury.</p>
            </div>
          </div>
        </div>

        <div class="mt-16 p-8 bg-zinc-900 text-center max-w-xl mx-auto">
          <p class="text-2xl font-black text-gradient">Real usage = Real value</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 sm:py-32 px-6 border-t border-zinc-800">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-4xl sm:text-5xl font-black mb-6">Join the Presale</h2>
        <p class="text-xl text-zinc-400 mb-10">
          Shared money deserves clean settlement. SplitDo delivers it.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/app/splitdo-exchange" class="px-10 py-4 bg-white text-zinc-950 font-bold">
            Get $SPLITDO
          </a>
          <a href="/about" class="px-10 py-4 text-zinc-300 hover:text-white font-semibold border-b-2 border-transparent hover:border-cyan-500 transition-all">
            About Us
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>
