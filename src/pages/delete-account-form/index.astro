---
import Layout from 'src/layouts/Layout.astro';

export const prerender = true;
---

<Layout title="Delete Account Request - SplitDo">
	<main class="min-h-screen bg-white dark:bg-gray-900">
		<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
			<div class="bg-white dark:bg-gray-800 shadow-lg rounded-lg p-8">
				<div class="text-center mb-8">
					<div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-red-100 dark:bg-red-900 mb-4">
						<svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.5 0L4.314 16.5c-.77.833.192 2.5 1.732 2.5z" />
						</svg>
					</div>
					<h1 class="text-3xl font-bold text-gray-900 dark:text-white">Delete Account Request</h1>
					<p class="mt-2 text-gray-600 dark:text-gray-400">
						Request deletion of your SplitDo account and associated data
					</p>
				</div>

				<div class="mb-6 p-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg">
					<h3 class="text-sm font-semibold text-yellow-800 dark:text-yellow-200 mb-2">Important Information</h3>
					<ul class="text-sm text-yellow-700 dark:text-yellow-300 space-y-1">
						<li>• Account deletion is permanent and cannot be undone</li>
						<li>• Your wallet private keys are stored locally - we cannot delete those</li>
						<li>• Blockchain transactions remain publicly visible</li>
						<li>• Some data may be retained for legal compliance</li>
						<li>• Processing may take up to 30 days</li>
					</ul>
				</div>

				<form class="space-y-6" action="#" method="POST">
					<div>
						<label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
							Email Address
						</label>
						<input
							type="email"
							id="email"
							name="email"
							required
							placeholder="Enter your account email"
							class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 dark:bg-gray-700 dark:text-white dark:placeholder-gray-400"
						>
					</div>

					<div>
						<label for="username" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
							Username (Optional)
						</label>
						<input
							type="text"
							id="username"
							name="username"
							placeholder="Enter your username if you remember it"
							class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 dark:bg-gray-700 dark:text-white dark:placeholder-gray-400"
						>
					</div>

					<div>
						<label for="reason" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
							Reason for Deletion (Optional)
						</label>
						<select
							id="reason"
							name="reason"
							class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 dark:bg-gray-700 dark:text-white"
						>
							<option value="">Select a reason (optional)</option>
							<option value="no-longer-using">No longer using the app</option>
							<option value="privacy-concerns">Privacy concerns</option>
							<option value="found-alternative">Found an alternative</option>
							<option value="technical-issues">Technical issues</option>
							<option value="other">Other</option>
						</select>
					</div>

					<div>
						<label for="additional-info" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
							Additional Information (Optional)
						</label>
						<textarea
							id="additional-info"
							name="additional-info"
							rows="4"
							placeholder="Any additional information or specific requests regarding your data deletion..."
							class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 dark:bg-gray-700 dark:text-white dark:placeholder-gray-400"
						></textarea>
					</div>

					<div class="flex items-start">
						<input
							type="checkbox"
							id="confirm-deletion"
							name="confirm-deletion"
							required
							class="mt-1 h-4 w-4 text-orange-600 focus:ring-orange-500 border-gray-300 rounded"
						>
						<label for="confirm-deletion" class="ml-2 block text-sm text-gray-700 dark:text-gray-300">
							I understand that this action is permanent and cannot be undone. I confirm that I want to delete my account and associated data.
						</label>
					</div>

					<div class="flex items-start">
						<input
							type="checkbox"
							id="backup-reminder"
							name="backup-reminder"
							required
							class="mt-1 h-4 w-4 text-orange-600 focus:ring-orange-500 border-gray-300 rounded"
						>
						<label for="backup-reminder" class="ml-2 block text-sm text-gray-700 dark:text-gray-300">
							I have backed up my wallet private keys and any important data from the app.
						</label>
					</div>

					<div class="pt-4">
						<button
							type="submit"
							class="w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors"
						>
							Submit Deletion Request
						</button>
					</div>
				</form>

				<div class="mt-8 pt-6 border-t border-gray-200 dark:border-gray-700">
					<div class="text-center">
						<p class="text-sm text-gray-600 dark:text-gray-400 mb-2">
							Need help or have questions?
						</p>
						<p class="text-sm">
							<a href="mailto:privacy@splitdo.com" class="text-orange-600 hover:text-orange-700 dark:text-orange-400 dark:hover:text-orange-300">
								Contact our privacy team
							</a>
						</p>
					</div>
				</div>

				<div class="mt-6 p-4 bg-gray-50 dark:bg-gray-700 rounded-lg">
					<h3 class="text-sm font-semibold text-gray-800 dark:text-gray-200 mb-2">What happens next?</h3>
					<ol class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
						<li>1. We'll verify your identity via the provided email address</li>
						<li>2. We'll send you a confirmation email with details</li>
						<li>3. Your data will be deleted within 30 days</li>
						<li>4. You'll receive a final confirmation once deletion is complete</li>
					</ol>
				</div>
			</div>
		</div>
	</main>
</Layout>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const form = document.querySelector('form');
		if (form) {
			form.addEventListener('submit', function(e) {
				e.preventDefault();

				const formData = new FormData(form);
				const email = formData.get('email');
				const confirmDeletion = formData.get('confirm-deletion');
				const backupReminder = formData.get('backup-reminder');

				if (!email) {
					alert('Please enter your email address.');
					return;
				}

				if (!confirmDeletion || !backupReminder) {
					alert('Please confirm both checkboxes to proceed.');
					return;
				}

				// Here you would normally submit to your backend
				// For now, we'll show a confirmation message
				alert('Deletion request submitted successfully. You will receive a confirmation email shortly.');

				// Optionally redirect or reset form
				form.reset();
			});
		}
	});
</script>
</Layout>