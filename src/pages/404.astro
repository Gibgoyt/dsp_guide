---
import Layout from 'src/layouts/Layout.astro';

export const prerender = true
---

<Layout title="404 - Page Not Found">
	<main>
		<!-- Hero Section -->
		<section class="min-h-screen flex items-center justify-center bg-gradient-to-b from-red-50 to-orange-50 dark:from-gray-900 dark:to-gray-800 py-16 lg:py-24">
			<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<!-- 404 Icon -->
				<div class="mb-8">
					<div class="w-32 h-32 bg-red-500 rounded-full flex items-center justify-center mx-auto mb-8 animate-bounce">
						<svg class="w-16 h-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
						</svg>
					</div>
				</div>

				<!-- 404 Text -->
				<h1 class="text-8xl md:text-9xl font-bold text-gray-900 dark:text-gray-100 mb-4">
					404
				</h1>
				
				<h2 class="text-3xl md:text-4xl font-bold text-gray-800 dark:text-gray-200 mb-6">
					Oops! Page Not Found
				</h2>
				
				<p class="text-xl text-gray-600 dark:text-gray-400 mb-8 max-w-2xl mx-auto">
					The page you're looking for doesn't exist. It might have been moved, deleted, or you entered the wrong URL.
				</p>

				<!-- Error Details -->
				<div class="bg-white dark:bg-gray-800 rounded-xl shadow-lg p-8 mb-8 max-w-2xl mx-auto">
					<h3 class="text-xl font-semibold mb-4 text-gray-900 dark:text-gray-100">What you can do:</h3>
					<ul class="text-left space-y-3 text-gray-600 dark:text-gray-300">
						<li class="flex items-start">
							<svg class="w-5 h-5 text-blue-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
							</svg>
							<span>Check the URL for typos</span>
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-blue-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
							</svg>
							<span>Go back to the previous page</span>
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-blue-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
							</svg>
							<span>Visit our homepage to find what you need</span>
						</li>
						<li class="flex items-start">
							<svg class="w-5 h-5 text-blue-500 mr-3 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
							</svg>
							<span>Use the search function if available</span>
						</li>
					</ul>
				</div>

				<!-- Action Buttons -->
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<button onclick="history.back()" 
						class="px-8 py-4 bg-gray-600 text-white text-lg rounded-lg hover:bg-gray-700 transition-colors shadow-lg hover:shadow-xl inline-flex items-center justify-center">
						<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
						</svg>
						Go Back
					</button>
					
					<a href="/apps" 
						class="px-8 py-4 bg-blue-600 text-white text-lg rounded-lg hover:bg-blue-700 transition-colors shadow-lg hover:shadow-xl inline-flex items-center justify-center">
						<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z"></path>
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 22V12h6v10"></path>
						</svg>
						Applications Hub
					</a>
					
					<a href="/" 
						class="px-8 py-4 bg-green-600 text-white text-lg rounded-lg hover:bg-green-700 transition-colors shadow-lg hover:shadow-xl inline-flex items-center justify-center">
						<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
						</svg>
						Home
					</a>
				</div>

				<!-- Fun Facts -->
				<div class="mt-12 p-6 bg-blue-50 dark:bg-blue-900/20 rounded-xl max-w-2xl mx-auto">
					<h3 class="text-lg font-semibold mb-3 text-blue-800 dark:text-blue-200">Fun Fact!</h3>
					<p class="text-blue-700 dark:text-blue-300">
						Did you know that 404 error gets its name from room number 404 at CERN, 
						where the World Wide Web was invented? Actually, that's a myth! The real 404 
						comes from HTTP status codes where 4xx indicates client errors.
					</p>
				</div>
			</div>
		</section>

		<!-- Search Suggestions (if you had search functionality) -->
		<section class="py-16 bg-gray-50 dark:bg-gray-900">
			<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<h3 class="text-2xl font-bold mb-8 text-gray-900 dark:text-gray-100">
					Popular Pages You Might Be Looking For
				</h3>
				
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					<a href="/apps" class="block p-6 bg-white dark:bg-gray-800 rounded-lg shadow hover:shadow-lg transition-shadow">
						<h4 class="font-semibold mb-2">Applications Hub</h4>
						<p class="text-gray-600 dark:text-gray-400 text-sm">Explore different frameworks and demos</p>
					</a>
					
					<a href="/apps/file-types/astro-demo" class="block p-6 bg-white dark:bg-gray-800 rounded-lg shadow hover:shadow-lg transition-shadow">
						<h4 class="font-semibold mb-2">Astro Components</h4>
						<p class="text-gray-600 dark:text-gray-400 text-sm">Learn about .astro file types</p>
					</a>
					
					<a href="/apps/file-types/markdown-demo" class="block p-6 bg-white dark:bg-gray-800 rounded-lg shadow hover:shadow-lg transition-shadow">
						<h4 class="font-semibold mb-2">Markdown Demo</h4>
						<p class="text-gray-600 dark:text-gray-400 text-sm">See Markdown in action</p>
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script>
	// Add some interactivity
	document.addEventListener('DOMContentLoaded', function() {
		// Track 404 error (you could send this to analytics)
		console.log('404 Error: Page not found', window.location.href);
		
		// Add keyboard shortcut to go home
		document.addEventListener('keydown', function(e) {
			if (e.key === 'h' && (e.ctrlKey || e.metaKey)) {
				e.preventDefault();
				window.location.href = '/';
			}
		});
	});
</script>