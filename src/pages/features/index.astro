---
import Layout from 'src/layouts/Layout.astro';
import WhitePhoneHero from 'src/components/WhitePhoneHero.astro';

// export static HTML
export const prerender = true
---

<Layout title="Features - SplitDo">

	<main>
		<!-- Hero Section - Side by Side (Text Left, Phones Right) -->
		<section class="w-full overflow-visible border-b-[10px] border-[#47a49e] dark:border-[#368179]">
			<style>
				:root {
					--color-background: #564740;
					--color-primary: #f07d40;
					--color-secondary: #47a49e;
				}

				/* Dark mode filter for feature hero image */
				.feature-hero-img {
					transition: filter 0.3s ease;
				}
				html.dark .feature-hero-img {
					filter: brightness(0.7) grayscale(0.3) contrast(0.9) !important;
				}
				.dark .feature-hero-img {
					filter: brightness(0.7) grayscale(0.3) contrast(0.9) !important;
				}
			</style>

			<div class="relative px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20 overflow-visible"
			        style="background: linear-gradient(to right, #564740, #55534C, #535F58, #4F766F, #47a49e);">


				<!-- Content container - Flex row with text left and phones right -->
				<div class="flex flex-col lg:flex-row items-center justify-center gap-2 sm:gap-3 lg:gap-4 relative max-w-7xl mx-auto">

					<!-- Left side: Text -->
					<div class="flex flex-col items-center justify-center w-full lg:w-auto lg:flex-1">
						<div class="flex flex-col gap-1.5 w-full text-center">
							<h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-4xl font-extrabold text-[#f07d40] dark:text-[#c8632f] tracking-normal sm:tracking-wide">
								Built for Simple, Secure,
							</h1>
							<h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-4xl font-extrabold text-[#47a49e] dark:text-[#368179] tracking-normal sm:tracking-wide">
								Smart Crypto Splitting
							</h1>
							<p class="text-sm sm:text-base lg:text-lg mt-3 leading-relaxed text-white dark:text-gray-300 text-balance">
								Whether you're traveling with friends, managing a DAO treasury, or splitting rent with roommates —
								Splitdo makes sharing expenses in crypto effortless.
							</p>
						</div>
					</div>

					<!-- Right side: Phones container - two phones (scaled smaller) -->
					<div class="flex justify-center items-center overflow-visible w-full lg:w-auto lg:flex-1">
						<WhitePhoneHero variant="compact" />
					</div>

				</div>
			</div>
		</section>

		<!-- Core Features -->
		<section class="w-full border-b-[10px] border-[#f07d40] dark:border-[#c8632f]">
			<div class="w-full">
				<div class="grid grid-cols-1 gap-0">
					<!-- Feature 1: Smart Expense Calculations (ORANGE) -->
					<div class="bg-[#f07d40] dark:bg-[#c8632f] text-white dark:text-gray-300 w-full">
						<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
							<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
								<div class="order-2 lg:order-1">
									<h3 class="text-2xl font-bold mb-4">Smart Expense Calculations</h3>
									<p class="text-white dark:text-gray-300 mb-6">
								Our intelligent algorithms don't just split bills—they understand context. Handle complex scenarios like unequal shares, tips, taxes, and custom distributions with mathematical precision.
							</p>
							<ul class="space-y-3">
								<li class="flex items-start">
									<svg class="w-5 h-5 mt-1 mr-3 flex-shrink-0" viewBox="0 0 20 20">
										<circle cx="10" cy="10" r="9" fill="#47a49e"/>
										<path d="M13.707 7.293a1 1 0 00-1.414 0L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 000-1.414z" fill="white" class="dark:fill-gray-300"/>
									</svg>
									<span class="text-white dark:text-gray-300">Handles complex splitting scenarios and custom rules</span>
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mt-1 mr-3 flex-shrink-0" viewBox="0 0 20 20">
										<circle cx="10" cy="10" r="9" fill="#47a49e"/>
										<path d="M13.707 7.293a1 1 0 00-1.414 0L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 000-1.414z" fill="white" class="dark:fill-gray-300"/>
									</svg>
									<span class="text-white dark:text-gray-300">Automatic tax and tip distribution calculations</span>
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mt-1 mr-3 flex-shrink-0" viewBox="0 0 20 20">
										<circle cx="10" cy="10" r="9" fill="#47a49e"/>
										<path d="M13.707 7.293a1 1 0 00-1.414 0L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 000-1.414z" fill="white" class="dark:fill-gray-300"/>
									</svg>
									<span class="text-white dark:text-gray-300">Real-time balance updates and debt optimization</span>
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mt-1 mr-3 flex-shrink-0" viewBox="0 0 20 20">
										<circle cx="10" cy="10" r="9" fill="#47a49e"/>
										<path d="M13.707 7.293a1 1 0 00-1.414 0L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 000-1.414z" fill="white" class="dark:fill-gray-300"/>
									</svg>
									<span class="text-white dark:text-gray-300">Supports all major currencies and payment methods</span>
								</li>
							</ul>
								</div>
								<!-- Right Column: Image -->
								<div class="order-1 lg:order-2 flex justify-center lg:justify-end">
									<img src="/splitdo/Features_page_Hero_Image.webp" alt="Smart Expense Calculations Illustration" class="max-w-full h-auto rounded-2xl shadow-xl feature-hero-img">
								</div>
							</div>
						</div>
					</div>
					<!-- Feature 2: Solana Blockchain Integration (BROWN) -->
					<div class="bg-[#564740] text-white dark:text-gray-300 w-full">
						<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
							<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
								<div class="order-1">
							<!-- Phone Mockup -->
							<div class="relative overflow-hidden max-w-[280px] sm:max-w-[340px] lg:max-w-[380px] w-full h-[350px] mx-auto">
								<div class="relative bg-[#2E2B29] rounded-[3rem] border-[6px] border-[#3D3530] shadow-2xl overflow-hidden w-full h-[520px] mx-auto">

									<!-- Top bar -->
									<div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-5 bg-[#2E2B29] rounded-b-2xl flex justify-center items-center z-10">
										<div class="w-10 h-1.5 bg-black rounded-full"></div>
									</div>

									<!-- Phone screen -->
									<div class="flex items-center justify-center h-full p-4">
										<div class="bg-white dark:bg-gray-300 rounded-[2.2rem] w-full h-full overflow-hidden">
											<div class="p-6">
												<div class="flex items-center space-x-2 mb-4">
													<svg class="w-4 h-4 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
														<path d="M4 3a2 2 0 00-2 2v1.586l8 8 8-8V5a2 2 0 00-2-2H4zM2 7.414V15a2 2 0 002 2h12a2 2 0 002-2V7.414l-8 8-8-8z"></path>
													</svg>
													<span class="font-mono text-xs text-gray-600">Payment Settlement</span>
												</div>
												<h1 class="text-lg font-bold mb-2 text-gray-900">Solana Payment</h1>
												<p class="text-xs text-gray-700 mb-3">Lightning-fast settlement with minimal fees.</p>

												<h2 class="text-sm font-semibold mb-1 text-gray-800">Transaction Details</h2>

												<h3 class="text-sm font-medium mb-1 text-gray-800">Amount: $24.75 USDC</h3>
												<p class="text-xs text-gray-700 mb-2">Split among 3 members - $8.25 each</p>

												<p class="font-medium text-gray-800 mb-1 text-xs">Settlement Status:</p>
												<div class="space-y-1">
													<div class="flex justify-between text-xs">
														<span class="text-gray-700">Alice → Bob</span>
														<span class="text-green-600">✓ Settled</span>
													</div>
													<div class="flex justify-between text-xs">
														<span class="text-gray-700">Charlie → Bob</span>
														<span class="text-orange-600">⏳ Pending</span>
													</div>
												</div>
											</div>
										</div>
									</div>

								</div>
							</div>
								</div>
								<div class="order-2">
									<h3 class="text-2xl font-bold mb-4">Solana Blockchain Integration</h3>
									<p class="text-white dark:text-gray-300">
								Leverage the speed and low costs of Solana blockchain for instant settlements. Connect your wallet and settle debts with minimal fees.
							</p>
							<ul class="space-y-3 mt-2">
								<li class="flex items-start">
									<svg class="w-5 h-5 mt-1 mr-3 flex-shrink-0" viewBox="0 0 20 20">
										<circle cx="10" cy="10" r="9" fill="#f07d40"/>
										<path d="M13.707 7.293a1 1 0 00-1.414 0L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 000-1.414z" fill="white" class="dark:fill-gray-300"/>
									</svg>
									<span class="text-white dark:text-gray-300">Lightning-fast transaction processing</span>
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mt-1 mr-3 flex-shrink-0" viewBox="0 0 20 20">
										<circle cx="10" cy="10" r="9" fill="#f07d40"/>
										<path d="M13.707 7.293a1 1 0 00-1.414 0L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 000-1.414z" fill="white" class="dark:fill-gray-300"/>
									</svg>
									<span class="text-white dark:text-gray-300">Minimal transaction fees (fractions of a penny)</span>
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mt-1 mr-3 flex-shrink-0" viewBox="0 0 20 20">
										<circle cx="10" cy="10" r="9" fill="#f07d40"/>
										<path d="M13.707 7.293a1 1 0 00-1.414 0L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 000-1.414z" fill="white" class="dark:fill-gray-300"/>
									</svg>
									<span class="text-white dark:text-gray-300">Support for USDC, SOL, and major tokens</span>
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mt-1 mr-3 flex-shrink-0" viewBox="0 0 20 20">
										<circle cx="10" cy="10" r="9" fill="#f07d40"/>
										<path d="M13.707 7.293a1 1 0 00-1.414 0L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 000-1.414z" fill="white" class="dark:fill-gray-300"/>
									</svg>
									<span class="text-white dark:text-gray-300">Secure, non-custodial wallet integration</span>
								</li>
							</ul>
								</div>
							</div>
						</div>
					</div>

					<!-- Feature 3: Group Management System (TEAL) -->
					<div class="bg-[#47a49e] dark:bg-[#368179] text-white dark:text-gray-300 w-full">
						<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
							<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
								<div class="order-2 lg:order-1">
									<h3 class="text-2xl font-bold mb-4">Group Management System</h3>
									<p class="text-white dark:text-gray-300">
								Create and manage expense groups with advanced permission controls, member management, and detailed activity tracking.
							</p>
							<ul class="space-y-3 mt-2">
								<li class="flex items-start">
									<svg class="w-5 h-5 mt-1 mr-3 flex-shrink-0" viewBox="0 0 20 20">
										<circle cx="10" cy="10" r="9" fill="#564740"/>
										<path d="M13.707 7.293a1 1 0 00-1.414 0L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 000-1.414z" fill="white" class="dark:fill-gray-300"/>
									</svg>
									<span class="text-white dark:text-gray-300">Role-based permissions for group administrators</span>
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mt-1 mr-3 flex-shrink-0" viewBox="0 0 20 20">
										<circle cx="10" cy="10" r="9" fill="#564740"/>
										<path d="M13.707 7.293a1 1 0 00-1.414 0L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 000-1.414z" fill="white" class="dark:fill-gray-300"/>
									</svg>
									<span class="text-white dark:text-gray-300">Invite members via email, phone, or QR code</span>
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mt-1 mr-3 flex-shrink-0" viewBox="0 0 20 20">
										<circle cx="10" cy="10" r="9" fill="#564740"/>
										<path d="M13.707 7.293a1 1 0 00-1.414 0L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 000-1.414z" fill="white" class="dark:fill-gray-300"/>
									</svg>
									<span class="text-white dark:text-gray-300">Real-time activity feeds and notifications</span>
								</li>
								<li class="flex items-start">
									<svg class="w-5 h-5 mt-1 mr-3 flex-shrink-0" viewBox="0 0 20 20">
										<circle cx="10" cy="10" r="9" fill="#564740"/>
										<path d="M13.707 7.293a1 1 0 00-1.414 0L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4a1 1 0 000-1.414z" fill="white" class="dark:fill-gray-300"/>
									</svg>
									<span class="text-white dark:text-gray-300">Detailed expense history and analytics</span>
								</li>
							</ul>
								</div>
								<div class="order-1 lg:order-2">
							<!-- Phone Mockup -->
							<div class="relative overflow-hidden max-w-[280px] sm:max-w-[340px] lg:max-w-[380px] w-full h-[350px] mx-auto">
								<div class="relative bg-[#2E2B29] rounded-[3rem] border-[6px] border-[#3D3530] shadow-2xl overflow-hidden w-full h-[520px] mx-auto">

									<!-- Top bar -->
									<div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-5 bg-[#2E2B29] rounded-b-2xl flex justify-center items-center z-10">
										<div class="w-10 h-1.5 bg-black rounded-full"></div>
									</div>

									<!-- Phone screen -->
									<div class="flex items-center justify-center h-full p-4">
										<div class="bg-white dark:bg-gray-300 rounded-[2.2rem] w-full h-full overflow-hidden">
											<div class="p-6">
												<div class="mb-3">
													<div class="text-base font-semibold text-gray-900">Weekend Trip Group</div>
												</div>
												<div class="space-y-2">
													<div class="p-2 bg-green-50 dark:bg-green-200/40 rounded-lg border border-green-200 dark:border-green-600">
														<div class="flex justify-between text-xs mb-0.5">
															<span class="font-semibold text-green-600">Alice (Admin)</span>
															<span class="text-green-600">+$15.25</span>
														</div>
														<p class="text-xs text-green-600">Paid for hotel</p>
													</div>
													<div class="p-2 bg-red-50 dark:bg-red-200/40 rounded-lg border border-red-200 dark:border-red-600">
														<div class="flex justify-between text-xs mb-0.5">
															<span class="font-semibold text-red-600">Bob</span>
															<span class="text-red-600">Owes: $8.75</span>
														</div>
														<p class="text-xs text-red-600">Gas & restaurant</p>
													</div>
													<div class="p-2 bg-blue-50 dark:bg-blue-200/40 rounded-lg border border-blue-200 dark:border-blue-600">
														<div class="flex justify-between text-xs mb-0.5">
															<span class="font-semibold text-blue-600">Charlie</span>
															<span class="text-blue-600">$0.00</span>
														</div>
														<p class="text-xs text-blue-600">Settled via Solana</p>
													</div>
												</div>
											</div>
										</div>
									</div>

								</div>
							</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Additional Features Grid -->
		<section class="w-full border-b-[10px] border-[#564740] dark:border-[#f07d40]">
			<div class="w-full">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-0">
					<!-- 1. Multi-Wallet Support (BROWN) -->
					<div class="flex flex-col items-center bg-[#564740] w-full">
						<div class="py-16 px-10 lg:px-12 text-white dark:text-gray-300 flex flex-col justify-center items-center w-full h-full">
							<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4">
								<svg class="w-8 h-8" style="color: white dark:gray-300;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"></path>
								</svg>
							</div>
							<h3 class="text-2xl font-semibold mb-3 text-center">Multi-Wallet Support</h3>
							<p class="text-base text-white dark:text-gray-300 text-center">
								Connect with Phantom, Solflare, Backpack, and other popular Solana wallets. Secure, non-custodial integration.
							</p>
						</div>
					</div>

					<!-- 2. Receipt Scanning (ORANGE) -->
					<div class="flex flex-col items-center bg-[#f07d40] dark:bg-[#c8632f] w-full">
						<div class="py-16 px-10 lg:px-12 text-white dark:text-gray-300 flex flex-col justify-center items-center w-full h-full">
							<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4">
								<svg class="w-8 h-8" style="color: white dark:gray-300;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
								</svg>
							</div>
							<h3 class="text-2xl font-semibold mb-3 text-center">Receipt Scanning</h3>
							<p class="text-base text-white dark:text-gray-300 text-center">
								AI-powered receipt scanning to automatically detect items, amounts, and split suggestions. Just snap a photo.
							</p>
						</div>
					</div>

					<!-- 3. Real-time Notifications (TEAL) -->
					<div class="flex flex-col items-center bg-[#47a49e] dark:bg-[#368179] w-full">
						<div class="py-16 px-10 lg:px-12 text-white dark:text-gray-300 flex flex-col justify-center items-center w-full h-full">
							<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4">
								<svg class="w-8 h-8" style="color: white dark:gray-300;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-5 5v-5zM4.828 17l2.828-2.828a4 4 0 015.656 0L15.172 17M9 12a3 3 0 100-6 3 3 0 000 6z"></path>
								</svg>
							</div>
							<h3 class="text-2xl font-semibold mb-3 text-center">Real-time Notifications</h3>
							<p class="text-base text-white dark:text-gray-300 text-center">
								Get instant alerts for new expenses, payment requests, and settlements. Push notifications and email updates.
							</p>
						</div>
					</div>

					<!-- 4. Expense Categories (BROWN) -->
					<div class="flex flex-col items-center bg-[#564740] w-full">
						<div class="py-16 px-10 lg:px-12 text-white dark:text-gray-300 flex flex-col justify-center items-center w-full h-full">
							<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4">
								<svg class="w-8 h-8" style="color: white dark:gray-300;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"></path>
								</svg>
							</div>
							<h3 class="text-2xl font-semibold mb-3 text-center">Expense Categories</h3>
							<p class="text-base text-white dark:text-gray-300 text-center">
								Smart categorization of expenses with detailed analytics. Track spending patterns and generate reports.
							</p>
						</div>
					</div>

					<!-- 5. Offline Mode (ORANGE) -->
					<div class="flex flex-col items-center bg-[#f07d40] dark:bg-[#c8632f] w-full">
						<div class="py-16 px-10 lg:px-12 text-white dark:text-gray-300 flex flex-col justify-center items-center w-full h-full">
							<div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4">
								<svg class="w-8 h-8" style="color: white dark:gray-300;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
