  <meta name="theme-color" content="#18181b">
  <meta name="color-scheme" content="dark">
  <meta name="robots" content="noindex, nofollow">
</head>
<body class="h-full bg-gray-900">
  <SvelteLoginForm client:load />
</body>
</html>
