  <script>
    function updateCountdown() {
      const target = new Date('2025-12-31T23:59:59').getTime();
      const now = Date.now();
      const diff = target - now;

      if (diff > 0) {
        const d = Math.floor(diff / 86400000);
        const h = Math.floor((diff % 86400000) / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);

        const de = document.getElementById('days');
        const he = document.getElementById('hours');
        const me = document.getElementById('minutes');
        const se = document.getElementById('seconds');

        if (de) de.textContent = d.toString().padStart(2, '0');
        if (he) he.textContent = h.toString().padStart(2, '0');
        if (me) me.textContent = m.toString().padStart(2, '0');
        if (se) se.textContent = s.toString().padStart(2, '0');
      }
    }

    setInterval(updateCountdown, 1000);
    updateCountdown();
  </script>
