---
import Layout from 'src/layouts/Layout.astro';

export const prerender = true
---

<Layout title="Phone SVG Demo - SplitDo">
  <style>
    .phone-container {
      transform-origin: center;
    }

    /* Scale down on smaller screens */
    @media (max-width: 1024px) {
      .phone-container {
        transform: scale(0.8);
      }
    }

    @media (max-width: 768px) {
      .phone-container {
        transform: scale(0.6);
      }
    }

    @media (max-width: 480px) {
      .phone-container {
        transform: scale(0.5);
      }
    }
  </style>
  <main class="bg-gray-100 py-12">

    <!-- Header -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
      <h1 class="text-4xl font-bold text-center mb-4">Angled Phone SVG Demo</h1>
      <p class="text-center text-gray-600">Testing all angled phone variations with 3D depth!</p>
    </div>

    <!-- Section 1: Phones WITHOUT Images -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16 overflow-visible">
      <h2 class="text-3xl font-bold mb-8 text-center">Without Images (Empty)</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 overflow-visible">

        <!-- Left Black -->
        <div class="bg-white p-6 rounded-lg shadow-lg overflow-visible">
          <h3 class="text-lg font-semibold mb-4 text-center">Left Black</h3>
          <svg width="650" height="950" viewBox="0 0 650 950" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
            <g transform="matrix(0.9, -0.1, -0.32, 1.05, 220, 80)">
              <!-- 3D Edge -->
              <g>
                <path d="M 335 50 L 350 50 L 350 630 L 335 630 L 335 50 Z" fill="#1A1F2E" opacity="0.8"/>
                <path d="M 335 50 Q 335 0, 285 0 L 300 0 Q 350 0, 350 50 L 335 50 Z" fill="#14181F" opacity="0.7"/>
                <path d="M 335 630 L 350 630 A 50 50 0 0 1 300 680 L 285 680 A 50 50 0 0 0 335 630 Z" fill="#14181F" opacity="0.7"/>
              </g>
              <rect x="0" y="0" width="335" height="680" rx="50" fill="#2D3748"/>
              <rect x="4" y="4" width="327" height="672" rx="46" fill="#3A4556"/>
              <g>
                <rect x="12" y="12" width="311" height="656" rx="42" fill="#1A202C"/>
