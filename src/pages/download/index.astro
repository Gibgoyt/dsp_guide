---
import Layout from 'src/layouts/Layout.astro';

export const prerender = true
---

<Layout 
  title="Download SPLITDO App | iOS, Android & Web - Crypto Bill Splitting"
  description="Download SPLITDO bill splitting app. Split expenses with crypto on iOS, Android, or web. Real-time sync, Solana blockchain settlements, group expense management with near-zero fees."
  keywords="SPLITDO app download, crypto bill splitting app, blockchain expense tracker, iOS Android crypto app, Solana payments app, expense sharing mobile app"
  ogType="website"
>
  <style>
    .text-gradient {
      background: linear-gradient(135deg, #22d3ee 0%, #3b82f6 50%, #8b5cf6 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hover-lift {
      transition: transform 0.3s ease;
    }
    .hover-lift:hover {
      transform: translateY(-4px);
    }
  </style>

  <main class="bg-zinc-950 text-white min-h-screen">

    <!-- Hero -->
    <section class="relative py-24 sm:py-32 px-6">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-cyan-500/10 rounded-full blur-[120px]"></div>
      
      <div class="relative max-w-5xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 mb-6">
          <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
          <span class="text-sm text-emerald-400 font-medium uppercase tracking-wider">Available Now</span>
        </div>

        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black mb-6">
          Get <span class="text-gradient">SplitDo</span>
        </h1>

        <p class="text-xl text-zinc-400 max-w-2xl mx-auto mb-12">
          Split expenses effortlessly. Available on iOS, Android, and Web.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#mobile" class="px-8 py-4 bg-white text-zinc-950 font-bold hover-lift">
            Download App
          </a>
          <a href="/app" class="px-8 py-4 text-zinc-300 hover:text-white font-semibold border-b-2 border-transparent hover:border-cyan-500 transition-all">
            Launch Web App
          </a>
        </div>
      </div>
    </section>

    <!-- Mobile Apps -->
    <section id="mobile" class="py-24 sm:py-32 px-6 bg-zinc-900/50">
      <div class="max-w-5xl mx-auto">
        <div class="mb-16">
          <h2 class="text-4xl sm:text-5xl font-black mb-4">Mobile Apps</h2>
          <p class="text-xl text-zinc-500">Native apps for iOS and Android.</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <!-- iOS -->
          <div class="group">
            <a 
              href="/download/istore"
              class="block p-8 bg-zinc-900 hover:bg-zinc-800 transition-colors hover-lift"
            >
              <div class="flex items-start gap-6">
                <div class="w-16 h-16 bg-zinc-800 flex items-center justify-center flex-shrink-0">
                  <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="text-2xl font-bold mb-2">iOS</h3>
                  <p class="text-zinc-500 mb-4">For iPhone and iPad</p>
                  <span class="text-cyan-400 font-medium group-hover:text-cyan-300 transition-colors flex items-center gap-2">
                    App Store
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          </div>

          <!-- Android -->
          <div class="group">
            <a 
              href="https://play.google.com/apps/testing/com.splitdo.app"
              target="_blank"
              rel="noopener"
              class="block p-8 bg-zinc-900 hover:bg-zinc-800 transition-colors hover-lift"
            >
              <div class="flex items-start gap-6">
                <div class="w-16 h-16 bg-zinc-800 flex items-center justify-center flex-shrink-0">
                  <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="text-2xl font-bold mb-2">Android</h3>
                  <p class="text-zinc-500 mb-4">For Android devices</p>
                  <span class="text-cyan-400 font-medium group-hover:text-cyan-300 transition-colors flex items-center gap-2">
                    Google Play
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Web App -->
    <section class="py-24 sm:py-32 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-4xl sm:text-5xl font-black mb-6">
              Or Use<br/>
              <span class="text-zinc-500">the Web.</span>
            </h2>
            <p class="text-xl text-zinc-400 mb-10">
              No download required. Access all features directly in your browser.
            </p>

            <div class="space-y-4 mb-10">
              <div class="flex items-center gap-3">
                <div class="w-1.5 h-1.5 bg-cyan-500"></div>
                <span class="text-zinc-300">Works on Chrome, Safari, Firefox, Edge</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-1.5 h-1.5 bg-cyan-500"></div>
                <span class="text-zinc-300">Real-time sync with mobile apps</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-1.5 h-1.5 bg-cyan-500"></div>
                <span class="text-zinc-300">Full blockchain settlement support</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-1.5 h-1.5 bg-cyan-500"></div>
                <span class="text-zinc-300">Zero installation</span>
              </div>
            </div>

            <a href="/app" class="inline-block px-8 py-4 bg-white text-zinc-950 font-bold hover-lift">
              Launch Web App
            </a>
          </div>

          <!-- Visual -->
          <div class="relative">
            <div class="absolute inset-0 bg-cyan-500/10 blur-3xl"></div>
            <div class="relative bg-zinc-900 p-8 flex items-center justify-center aspect-video">
              <svg class="w-24 h-24 text-zinc-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="py-24 sm:py-32 px-6 bg-zinc-900/50">
      <div class="max-w-5xl mx-auto">
        <div class="mb-16">
          <h2 class="text-4xl sm:text-5xl font-black mb-4">Why SplitDo?</h2>
          <p class="text-xl text-zinc-500">The most advanced expense splitting platform.</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
          <div>
            <h3 class="text-lg font-bold mb-2">Lightning Fast</h3>
            <p class="text-zinc-500 text-sm">Instant Solana settlements with near-zero fees.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold mb-2">Groups</h3>
            <p class="text-zinc-500 text-sm">Unlimited groups with custom permissions.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold mb-2">Secure</h3>
            <p class="text-zinc-500 text-sm">Non-custodial wallet integration.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold mb-2">Synced</h3>
            <p class="text-zinc-500 text-sm">Real-time sync across all devices.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 sm:py-32 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-4xl sm:text-5xl font-black mb-6">Ready?</h2>
        <p class="text-xl text-zinc-400 mb-10">
          Join thousands using SplitDo for seamless expense management.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#mobile" class="px-10 py-4 bg-white text-zinc-950 font-bold hover-lift">
            Download App
          </a>
          <a href="/app" class="px-10 py-4 bg-zinc-800 text-white font-bold hover:bg-zinc-700 transition-colors">
            Web App
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>
