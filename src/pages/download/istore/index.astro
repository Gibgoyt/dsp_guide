---
import Layout from 'src/layouts/Layout.astro';

// export static HTML
export const prerender = true
---

<Layout title="App Store - Coming Soon - SplitDo">

	<main>
		<!-- Hero Section -->
		<section class="w-full overflow-visible border-b-[10px] border-[#47a49e] dark:border-[#f07d40]">
			<style>
				:root {
					--color-background: #564740;
					--color-primary: #f07d40;
					--color-secondary: #47a49e;
				}
			</style>

			<div class="relative px-4 sm:px-6 lg:px-8 py-12 sm:py-16 lg:py-20 overflow-visible"
   			        style="background: linear-gradient(to right, #564740, #55534C, #535F58, #4F766F, #47a49e);">

				<!-- Content container -->
				<div class="flex flex-col items-center justify-center gap-6 relative max-w-4xl mx-auto text-center">

					<!-- App Store Icon -->
					<div class="w-24 h-24 bg-white dark:bg-gray-300 rounded-2xl flex items-center justify-center shadow-lg">
						<svg class="w-16 h-16 text-black" viewBox="0 0 24 24" fill="currentColor">
							<path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
						</svg>
					</div>

					<!-- Heading -->
					<div class="flex flex-col gap-2">
						<h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-[#f07d40] dark:text-[#c8632f] tracking-wide">
							Coming Soon
						</h1>
						<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-[#47a49e] dark:text-[#368179]">
							to the App Store
						</h2>
					</div>

					<!-- Description -->
					<p class="text-lg sm:text-xl mt-4 leading-relaxed text-white dark:text-gray-300 max-w-2xl">
						We're working hard to bring SplitDo to the Apple App Store. In the meantime, you can use our web app or download from Google Play.
					</p>

					<!-- Back to Download Button -->
					<a href="/download" class="mt-6 px-8 py-4 bg-[#f07d40] dark:bg-[#c8632f] text-black text-lg rounded-lg hover:scale-105 transition-transform shadow-lg hover:shadow-xl font-semibold">
						Back to Downloads
					</a>

				</div>
			</div>
		</section>

		<!-- Alternative Options Section -->
		<section class="py-16 lg:py-24 bg-[#f07d40] dark:bg-[#564740] border-b-[10px] border-[#564740] dark:border-[#f07d40]">
			<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="text-center mb-12">
					<h2 class="text-3xl font-bold mb-4 text-black dark:text-gray-300">Available Now</h2>
					<p class="text-lg text-black dark:text-gray-300">
						Get started with SplitDo today using these options
					</p>
				</div>

				<div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
					<!-- Web App Button -->
					<a href="/app" class="inline-block transform hover:scale-105 transition-transform duration-200">
						<div class="bg-[#47a49e] dark:bg-[#368179] text-white rounded-lg px-6 py-4 flex items-center space-x-3 min-w-[220px]">
							<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
							</svg>
							<div class="text-left">
								<div class="text-sm font-medium">Launch</div>
								<div class="text-xl font-bold leading-tight">Web App</div>
							</div>
						</div>
					</a>

					<!-- Google Play Button -->
					<a href="https://play.google.com/apps/testing/com.splitdo.app" class="inline-block transform hover:scale-105 transition-transform duration-200">
						<div class="bg-black text-white dark:bg-gray-300 dark:text-black rounded-lg px-6 py-4 flex items-center space-x-3 min-w-[220px]">
							<svg class="w-10 h-10" viewBox="0 0 24 24" fill="currentColor">
								<path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.6 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
							</svg>
							<div class="text-left">
								<div class="text-sm font-medium">Get it on</div>
								<div class="text-xl font-bold leading-tight">Google Play</div>
							</div>
						</div>
					</a>
				</div>
			</div>
		</section>

		<!-- Stay Updated Section -->
		<section class="py-16 lg:py-24 bg-[#47a49e] dark:bg-[#368179]">
			<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
				<h2 class="text-3xl font-bold mb-4 text-white dark:text-gray-300">Want to be notified?</h2>
				<p class="text-lg text-white dark:text-gray-300 mb-8">
					We'll announce the App Store launch on our social media channels. Stay tuned!
				</p>
				<a href="/" class="inline-block px-8 py-4 bg-[#f07d40] dark:bg-[#c8632f] text-black text-lg rounded-lg hover:scale-105 transition-transform shadow-lg hover:shadow-xl font-semibold">
					Back to Home
				</a>
			</div>
		</section>
	</main>

</Layout>
