{
  "name": "ai-docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev --remote --port 2084",
    "dev:https": "concurrently \"npm run dev\" \"node https-proxy.js\"",
    "proxy": "node https-proxy.js",
    "build:admin_app": "cd src/applications_leptos/admin_app && ./build.sh",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "clean": "./clean.sh",
    "lint": "eslint . --ext .js,.ts,.tsx,.astro,.svelte",
    "lint:fix": "eslint . --ext .js,.ts,.tsx,.astro,.svelte --fix",
    "typecheck": "astro check && tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "wrangler-dev": "npx wrangler pages dev ./dist --ip 0.0.0.0 --port 3001",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:preview": "npm run build && wrangler pages deploy dist --branch preview"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/cloudflare": "^12.6.0",
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/solid-js": "^5.1.0",
    "@astrojs/svelte": "^7.1.0",
    "@builder.io/qwik": "^1.14.1",
    "@metamask/solana-wallet-snap": "^2.6.2",
    "@qwikdev/astro": "^0.8.0",
    "@solana/spl-token": "^0.1.8",
    "@solana/web3.js": "^1.95.2",
    "@tailwindcss/vite": "^4.1.8",
    "@wallet-standard/app": "^1.0.3",
    "@wallet-standard/base": "^1.0.1",
    "@wallet-standard/core": "^1.1.1",
    "@wallet-standard/features": "^1.0.3",
    "@wallet-standard/wallet": "^1.0.1",
    "@walletconnect/sign-client": "^2.17.2",
    "@walletconnect/types": "^2.17.2",
    "@walletconnect/utils": "^2.17.2",
    "amazon-cognito-identity-js": "^6.3.15",
    "astro": "^5.9.1",
    "buffer": "^6.0.3",
    "concurrently": "^9.2.1",
    "firebase": "^12.6.0",
    "htmx.org": "^1.9.12",
    "http-proxy": "^1.18.1",
    "qrcode": "^1.5.4",
    "solid-js": "^1.9.7",
    "svelte": "^5.33.18",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitest/ui": "^4.0.17",
    "eslint": "^9.15.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-qwik": "^1.9.0",
    "eslint-plugin-svelte": "^2.46.0",
    "jsdom": "^25.0.1",
    "vitest": "^4.0.17",
    "wrangler": "^4.19.1"
  }
}
